@model IEnumerable<FreelancerManagementSystem.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Projects</h1>
        <a asp-action="Create" class="btn btn-primary">Create New Project</a>
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">@item.Name</h5>
                        <h6 class="card-subtitle mb-2 text-muted">Status: @item.Status</h6>
                        <p class="card-text">@item.Description</p>
                        <p class="card-text">
                            <strong>Budget:</strong> $@item.Budget<br />
                            <strong>Start Date:</strong> @item.StartDate.ToShortDateString()<br />
                            @if (item.EndDate.HasValue)
                            {
                                <strong>End Date:</strong> 
                                @item.EndDate.Value.ToShortDateString()
                            }
                        </p>
                        <div class="btn-group" role="group">
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>