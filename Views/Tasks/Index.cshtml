@{
    ViewData["Title"] = "Tasks Board";
}

<div class="container-fluid mt-4">
    <h1 class="mb-4">Tasks Board</h1>
    
    <div class="row">
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0">Todo</h5>
                </div>
                <div class="card-body" style="min-height: 500px;">
                    <div class="task-list" id="todo-tasks">
                        <!-- Tasks will be loaded here via JavaScript -->
                    </div>
                    <button class="btn btn-sm btn-primary mt-2" onclick="addTask('Todo')">+ Add Task</button>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">In Progress</h5>
                </div>
                <div class="card-body" style="min-height: 500px;">
                    <div class="task-list" id="inprogress-tasks">
                        <!-- Tasks will be loaded here via JavaScript -->
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">Review</h5>
                </div>
                <div class="card-body" style="min-height: 500px;">
                    <div class="task-list" id="review-tasks">
                        <!-- Tasks will be loaded here via JavaScript -->
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card bg-light">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">Done</h5>
                </div>
                <div class="card-body" style="min-height: 500px;">
                    <div class="task-list" id="done-tasks">
                        <!-- Tasks will be loaded here via JavaScript -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
    <script>
        // Sample tasks data
        let tasks = [
        { id: 1, title: "Setup Database", status: "Todo", priority: "High" },
        { id: 2, title: "Create Models", status: "Todo", priority: "Medium" },
        { id: 3, title: "Implement API", status: "InProgress", priority: "High" },
        { id: 4, title: "Create Views", status: "Review", priority: "Medium" },
        { id: 5, title: "Testing", status: "Done", priority: "Low" }
        ];
        
        function loadTasks() {
        // Clear all task lists
        document.getElementById('todo-tasks').innerHTML = '';
        document.getElementById('inprogress-tasks').innerHTML = '';
        document.getElementById('review-tasks').innerHTML = '';
        document.getElementById('done-tasks').innerHTML = '';
            
        tasks.forEach(task => {
        const taskElement = createTaskElement(task);
        if (task.status === 'Todo') {
        document.getElementById('todo-tasks').appendChild(taskElement);
        } else if (task.status === 'InProgress') {
        document.getElementById('inprogress-tasks').appendChild(taskElement);
        } else if (task.status === 'Review') {
        document.getElementById('review-tasks').appendChild(taskElement);
        } else if (task.status === 'Done') {
        document.getElementById('done-tasks').appendChild(taskElement);
        }
        });
        }
        
        function createTaskElement(task) {
        const div = document.createElement('div');
        div.className = 'card mb-2 task-card';
        div.setAttribute('data-id', task.id);
        div.innerHTML = `
        <div class="card-body p-2">
        <h6 class="card-title mb-1">${task.title}</h6>
        <p class="card-text small mb-1">Priority: ${task.priority}</p>
        <button class="btn btn-sm btn-outline-danger" onclick="deleteTask(${task.id})">Delete</button>
        </div>
        `;
        return div;
        }
        
        function addTask(status) {
        const title = prompt("Enter task title:");
        if (title) {
        const newTask = {
        id: Date.now(),
        title: title,
        status: status,
        priority: "Medium"
        };
        tasks.push(newTask);
        loadTasks();
        }
        }
        
        function deleteTask(id) {
        if (confirm("Are you sure you want to delete this task?")) {
        tasks = tasks.filter(t => t.id !== id);
        loadTasks();
        }
        }
        
        // Initialize Sortable for drag and drop
        const todoList = document.getElementById('todo-tasks');
        const inprogressList = document.getElementById('inprogress-tasks');
        const reviewList = document.getElementById('review-tasks');
        const doneList = document.getElementById('done-tasks');
        
        new Sortable(todoList, {
        group: 'shared',
        animation: 150,
        onEnd: function() {
        updateTaskStatuses();
        }
        });
        
        new Sortable(inprogressList, {
        group: 'shared',
        animation: 150,
        onEnd: function() {
        updateTaskStatuses();
        }
        });
        
        new Sortable(reviewList, {
        group: 'shared',
        animation: 150,
        onEnd: function() {
        updateTaskStatuses();
        }
        });
        
        new Sortable(doneList, {
        group: 'shared',
        animation: 150,
        onEnd: function() {
        updateTaskStatuses();
        }
        });
        
        function updateTaskStatuses() {
        // This would update the status of tasks in the database
        console.log("Tasks updated");
        }
        
        // Load initial tasks
        loadTasks();
    </script>
}